{
  "name": "pathfinder-mcp",
  "version": "1.0.0",
  "description": "Pathfinder MCP Server — AI-powered browser test execution",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "dev": "tsx --env-file=.env src/index.ts",
    "setup": "npm install && npx playwright install chromium",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@xenova/transformers": "^2.17.2",
    "linkedom": "^0.18.12",
    "mysql2": "^3.14.1",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.52.0",
    "pngjs": "^7.0.0",
    "zod": "^3.25.20"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/pngjs": "^6.0.5",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
